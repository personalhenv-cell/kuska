# ─────────────────────────────────────────────────────────────
# KUSKA — Variables de entorno (plantilla, sin secretos)
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore y NUNCA debe subirse al repo.
# ─────────────────────────────────────────────────────────────

# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js / NextAuth
AUTH_SECRET="genera-un-secreto-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# IA — Google Gemini (Kuska IA)
GEMINI_API_KEY=""

# Chat en tiempo real — Pusher
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# Imágenes — Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Emails — Resend
RESEND_API_KEY=""

# Videos — Mux
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""

# Monitoreo
SENTRY_DSN=""
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""
